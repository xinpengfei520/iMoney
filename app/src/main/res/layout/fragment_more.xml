<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/dp_24">

        <!-- Header 卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_16"
            android:background="@drawable/bg_more_header"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="@dimen/dp_20">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="iMoney"
                android:textColor="@android:color/white"
                android:textSize="@dimen/dp_22"
                android:textStyle="bold" />

            <com.xpf.p2p.widget.MyTextView
                android:id="@+id/tv_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:text="@string/marquee_text"
                android:textColor="#B3FFFFFF"
                android:textSize="@dimen/dp_13" />

        </LinearLayout>

        <!-- 常用功能 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_20"
            android:layout_marginBottom="@dimen/dp_8"
            android:text="常用功能"
            android:textColor="#333333"
            android:textSize="@dimen/dp_15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_16"
            android:background="@drawable/bg_more_card"
            android:clipChildren="true"
            android:elevation="@dimen/dp_1"
            android:orientation="vertical">

            <!-- 多语言 -->
            <LinearLayout
                android:id="@+id/item_language"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_50"
                android:background="@drawable/bg_more_item"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/dp_16"
                android:paddingEnd="@dimen/dp_16">

                <TextView
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:background="#1018B4ED"
                    android:gravity="center"
                    android:text="\uD83C\uDF10"
                    android:textSize="@dimen/dp_16" />

                <TextView
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_12"
                    android:layout_weight="1"
                    android:text="@string/multi_language"
                    android:textColor="#333333"
                    android:textSize="@dimen/dp_15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u203A"
                    android:textColor="#BDBDBD"
                    android:textSize="@dimen/dp_20" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:layout_marginStart="@dimen/dp_58"
                android:background="#F0F0F0" />

            <!-- 消息通知 -->
            <LinearLayout
                android:id="@+id/item_notification"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_50"
                android:background="@drawable/bg_more_item"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/dp_16"
                android:paddingEnd="@dimen/dp_16">

                <TextView
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:background="#10FF9800"
                    android:gravity="center"
                    android:text="\uD83D\uDD14"
                    android:textSize="@dimen/dp_16" />

                <TextView
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_12"
                    android:layout_weight="1"
                    android:text="消息通知"
                    android:textColor="#333333"
                    android:textSize="@dimen/dp_15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u203A"
                    android:textColor="#BDBDBD"
                    android:textSize="@dimen/dp_20" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:layout_marginStart="@dimen/dp_58"
                android:background="#F0F0F0" />

            <!-- 安全中心 -->
            <LinearLayout
                android:id="@+id/item_security"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_50"
                android:background="@drawable/bg_more_item"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/dp_16"
                android:paddingEnd="@dimen/dp_16">

                <TextView
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:background="#104CAF50"
                    android:gravity="center"
                    android:text="\uD83D\uDD12"
                    android:textSize="@dimen/dp_16" />

                <TextView
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_12"
                    android:layout_weight="1"
                    android:text="安全中心"
                    android:textColor="#333333"
                    android:textSize="@dimen/dp_15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u203A"
                    android:textColor="#BDBDBD"
                    android:textSize="@dimen/dp_20" />

            </LinearLayout>

        </LinearLayout>

        <!-- 系统设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_20"
            android:layout_marginBottom="@dimen/dp_8"
            android:text="系统设置"
            android:textColor="#333333"
            android:textSize="@dimen/dp_15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_16"
            android:background="@drawable/bg_more_card"
            android:clipChildren="true"
            android:elevation="@dimen/dp_1"
            android:orientation="vertical">

            <!-- 清除缓存 -->
            <LinearLayout
                android:id="@+id/item_clear_cache"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_50"
                android:background="@drawable/bg_more_item"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/dp_16"
                android:paddingEnd="@dimen/dp_16">

                <TextView
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:background="#10F44336"
                    android:gravity="center"
                    android:text="\uD83D\uDDD1"
                    android:textSize="@dimen/dp_16" />

                <TextView
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_12"
                    android:layout_weight="1"
                    android:text="清除缓存"
                    android:textColor="#333333"
                    android:textSize="@dimen/dp_15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u203A"
                    android:textColor="#BDBDBD"
                    android:textSize="@dimen/dp_20" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:layout_marginStart="@dimen/dp_58"
                android:background="#F0F0F0" />

            <!-- 检查更新 -->
            <LinearLayout
                android:id="@+id/item_check_update"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_50"
                android:background="@drawable/bg_more_item"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/dp_16"
                android:paddingEnd="@dimen/dp_16">

                <TextView
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:background="#109C27B0"
                    android:gravity="center"
                    android:text="\u2B06\uFE0F"
                    android:textSize="@dimen/dp_16" />

                <TextView
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_12"
                    android:layout_weight="1"
                    android:text="检查更新"
                    android:textColor="#333333"
                    android:textSize="@dimen/dp_15" />

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#BDBDBD"
                    android:textSize="@dimen/dp_13" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_4"
                    android:text="\u203A"
                    android:textColor="#BDBDBD"
                    android:textSize="@dimen/dp_20" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:layout_marginStart="@dimen/dp_58"
                android:background="#F0F0F0" />

            <!-- 关于我们 -->
            <LinearLayout
                android:id="@+id/item_about"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_50"
                android:background="@drawable/bg_more_item"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/dp_16"
                android:paddingEnd="@dimen/dp_16">

                <TextView
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:background="#103F51B5"
                    android:gravity="center"
                    android:text="\u2139\uFE0F"
                    android:textSize="@dimen/dp_16" />

                <TextView
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_12"
                    android:layout_weight="1"
                    android:text="关于我们"
                    android:textColor="#333333"
                    android:textSize="@dimen/dp_15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u203A"
                    android:textColor="#BDBDBD"
                    android:textSize="@dimen/dp_20" />

            </LinearLayout>

        </LinearLayout>

        <!-- GitHub 开源项目入口 -->
        <LinearLayout
            android:id="@+id/item_github"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_24"
            android:layout_marginEnd="@dimen/dp_16"
            android:background="@drawable/bg_github_btn"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/dp_12">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GitHub"
                android:textColor="#333333"
                android:textSize="@dimen/dp_14"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_6"
                android:text="View source on GitHub"
                android:textColor="#828282"
                android:textSize="@dimen/dp_13" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
